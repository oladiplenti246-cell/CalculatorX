<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/gradient_bg"
    android:padding="16dp"
    android:gravity="bottom"
    android:fitsSystemWindows="true">

    <!-- Push content to bottom -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Header with Scientific Toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical|end"
        android:layout_marginBottom="4dp">

        <Button
            android:id="@+id/btnToggleScientific"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:paddingHorizontal="12dp"
            android:text="Scientific Mode"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:background="@drawable/display_bg"
            android:alpha="0.8" />
    </LinearLayout>

    <!-- Display -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/display_bg"
        android:padding="24dp"
        android:orientation="vertical"
        android:gravity="bottom|end">

        <TextView
            android:id="@+id/tvPrevious"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#CCFFFFFF"
            android:textSize="18sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvDisplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="56sp"
            android:textStyle="bold"
            android:gravity="end"
            android:maxLines="1"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="32sp"
            app:autoSizeMaxTextSize="56sp"
            app:autoSizeStepGranularity="2sp" />

    </LinearLayout>

    <!-- Scientific Buttons Grid (Initially Hidden) -->
    <GridLayout
        android:id="@+id/scientificGrid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:layout_marginBottom="8dp"
        android:visibility="gone">

        <Button android:id="@+id/btnSin" style="@style/BtnScientific" android:text="sin" />
        <Button android:id="@+id/btnCos" style="@style/BtnScientific" android:text="cos" />
        <Button android:id="@+id/btnTan" style="@style/BtnScientific" android:text="tan" />
        <Button android:id="@+id/btnLog" style="@style/BtnScientific" android:text="log" />

        <Button android:id="@+id/btnSqrt" style="@style/BtnScientific" android:text="√" />
        <Button android:id="@+id/btnPow" style="@style/BtnScientific" android:text="x²" />
        <Button android:id="@+id/btnPi" style="@style/BtnScientific" android:text="π" />
        <Button android:id="@+id/btnFactorial" style="@style/BtnScientific" android:text="n!" />

    </GridLayout>

    <!-- Button Grid -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:rowCount="5"
        android:useDefaultMargins="false"
        android:rowOrderPreserved="true">

        <!-- Row 1 -->
        <Button android:id="@+id/btnClear" style="@style/BtnFunction" android:text="C" />
        <Button android:id="@+id/btnDivide" style="@style/BtnOperator1" android:text="÷" />
        <Button android:id="@+id/btnMultiply" style="@style/BtnOperator2" android:text="×" />
        <Button android:id="@+id/btnBackspace" style="@style/BtnFunction2" android:text="←" />

        <!-- Row 2 -->
        <Button android:id="@+id/btn7" style="@style/BtnNumber1" android:text="7" />
        <Button android:id="@+id/btn8" style="@style/BtnNumber1" android:text="8" />
        <Button android:id="@+id/btn9" style="@style/BtnNumber1" android:text="9" />
        <Button android:id="@+id/btnMinus" style="@style/BtnOperator3" android:text="−" />

        <!-- Row 3 -->
        <Button android:id="@+id/btn4" style="@style/BtnNumber2" android:text="4" />
        <Button android:id="@+id/btn5" style="@style/BtnNumber2" android:text="5" />
        <Button android:id="@+id/btn6" style="@style/BtnNumber2" android:text="6" />
        <Button android:id="@+id/btnPlus" style="@style/BtnOperator4" android:text="+" />

        <!-- Row 4 -->
        <Button android:id="@+id/btn1" style="@style/BtnNumber3" android:text="1" />
        <Button android:id="@+id/btn2" style="@style/BtnNumber3" android:text="2" />
        <Button android:id="@+id/btn3" style="@style/BtnNumber3" android:text="3" />
        <Button android:id="@+id/btnPercent" style="@style/BtnNumber4" android:text="%" />

        <!-- Row 5 -->
        <Button android:id="@+id/btn0" style="@style/BtnNumber5" android:text="0" />
        <Button android:id="@+id/btnDot" style="@style/BtnNumber5" android:text="." />
        <Button android:id="@+id/btnSign" style="@style/BtnNumber6" android:text="+/-" />
        <Button android:id="@+id/btnEquals" style="@style/BtnEquals" android:text="=" />

    </GridLayout>

</LinearLayout>